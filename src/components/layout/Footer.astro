---
import ShareButtons from '../marketing/ShareButtons.astro';

const quickLinks = [
  { label: 'Inicio', href: '#inicio' },
  { label: 'Servicios', href: '#servicios' },
  { label: 'Productos', href: '#productos' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const services = [
  { label: 'Consultorías', href: '#servicios' },
  { label: 'Servicios científicos', href: '#servicios' },
  { label: 'Eventos', href: '#servicios' },
  { label: 'Gestión de proyectos', href: '#servicios' },
  { label: 'Servicios internacionales', href: '#servicios' },
];

const contactInfo = {
  phone: '(53) 24 483146',
  email: 'eict@uho.edu.cu',
  facebook: 'https://www.facebook.com/EICT-S.A-123456789',
  instagram: 'https://www.instagram.com/eict-s-a',
};
---

<footer class="bg-eict-purple dark:bg-slate-900 text-white">
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <div>
        <div class="flex items-center space-x-2 mb-6">
          <div class="w-12 h-12 bg-white rounded-lg flex items-center justify-center">
            <span class="text-eict-purple font-bold text-xl">E</span>
          </div>
          <div>
            <span class="text-2xl font-bold">EICT S.A.</span>
            <p class="text-eict-cyan-light text-sm">Solucionamos con ciencia</p>
          </div>
        </div>
        <p class="text-gray-300 mb-6">
          Sociedad de Interfaz de Ciencia y Tecnología. Conectando la investigación con la empresa para innovar y crecer.
        </p>
        <ShareButtons />
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-6">Enlaces Rápidos</h3>
        <ul class="space-y-3">
          {quickLinks.map(link => (
            <li>
              <a href={link.href} class="text-gray-300 hover:text-eict-cyan transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-6">Servicios</h3>
        <ul class="space-y-3">
          {services.map(service => (
            <li>
              <a href={service.href} class="text-gray-300 hover:text-eict-cyan transition-colors duration-200">
                {service.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-semibold mb-6">Contacto</h3>
        <ul class="space-y-4">
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-eict-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${contactInfo.phone}`} class="text-gray-300 hover:text-eict-cyan transition-colors duration-200">
              {contactInfo.phone}
            </a>
          </li>
          <li class="flex items-center space-x-3">
            <svg class="w-5 h-5 text-eict-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${contactInfo.email}`} class="text-gray-300 hover:text-eict-cyan transition-colors duration-200">
              {contactInfo.email}
            </a>
          </li>
        </ul>
        <div class="flex space-x-4 mt-6">
          <a href={contactInfo.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-eict-cyan transition-colors duration-200" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
            </svg>
          </a>
          <a href={contactInfo.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center hover:bg-eict-cyan transition-colors duration-200" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="2" />
              <circle cx="17.5" cy="6.5" r="1.5" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
        <p class="text-gray-400 text-sm">
          © 2026 EICT S.A. Todos los derechos reservados.
        </p>
        <div class="flex space-x-6 text-sm">
          <a href="#" class="text-gray-400 hover:text-eict-cyan transition-colors duration-200">
            Política de Privacidad
          </a>
          <a href="#" class="text-gray-400 hover:text-eict-cyan transition-colors duration-200">
            Términos de Uso
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>