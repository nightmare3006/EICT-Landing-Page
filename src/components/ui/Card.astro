---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`bg-white dark:bg-slate-800 rounded-xl shadow-md overflow-hidden transition-all duration-300 hover:transform hover:-translate-y-1 hover:shadow-lg hover:border-eict-cyan border border-transparent ${className}`}>
  <slot />
</div>