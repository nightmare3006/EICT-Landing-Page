---
interface Props {
  class?: string;
  hover?: 'lift' | 'glow' | 'none';
}

const { class: className = '', hover = 'lift' } = Astro.props;

const hoverClasses = {
  lift: 'hover:-translate-y-2 hover:shadow-xl',
  glow: 'hover:shadow-lg hover:shadow-eict-cyan/10 hover:border-eict-cyan/30',
  none: '',
};
---

<div
  class={`bg-white dark:bg-slate-800/90 rounded-2xl shadow-md border border-gray-100 dark:border-slate-700/50 transition-all duration-300 ${hoverClasses[hover]} ${className}`}
>
  <slot />
</div>