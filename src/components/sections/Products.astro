---
import { getCollection } from 'astro:content';
import SectionTitle from '../ui/SectionTitle.astro';
import Card from '../ui/Card.astro';

const productos = await getCollection('productos');
const disponibles = productos.filter(p => p.data.available !== false);
const iconPaths = {
  intangible: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  tecnologia: 'M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z',
  servicio: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
  otro: 'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10',
};
const colorMap = {
  intangible: 'from-amber-400 to-orange-500',
  tecnologia: 'from-blue-400 to-blue-600',
  servicio: 'from-emerald-400 to-emerald-600',
  otro: 'from-violet-400 to-violet-600',
};
---

<section id="productos" class="py-24 bg-white dark:bg-slate-900">
  <div class="container mx-auto px-4">
    <SectionTitle
      title="Portafolio"
      subtitle="Explora nuestra oferta de productos y servicios basados en ciencia e innovación"
      centered
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {disponibles.map((p) => {
        const cat = p.data.category ?? 'otro';
        return (
          <Card hover="glow" class="text-center">
            <div class="p-8">
              <div class={`w-16 h-16 mx-auto mb-5 bg-gradient-to-br ${colorMap[cat] ?? colorMap.otro} rounded-2xl flex items-center justify-center`}>
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[cat] ?? iconPaths.otro} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-eict-purple dark:text-white mb-2">{p.data.title}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400">{p.data.description}</p>
              {p.data.price && (
                <p class="text-sm font-semibold text-eict-cyan mt-3">{p.data.price}</p>
              )}
            </div>
          </Card>
        );
      })}
    </div>

    <div class="text-center">
      <div class="inline-flex items-center gap-3 px-6 py-4 bg-eict-gray-light/50 dark:bg-slate-800 rounded-2xl border border-dashed border-eict-gray-blue dark:border-slate-600">
        <svg class="w-6 h-6 text-eict-cyan animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="text-gray-600 dark:text-gray-400">
          <span class="font-semibold text-eict-purple dark:text-white">Próximamente:</span> Estamos desarrollando nuevos productos. Suscríbete para recibir novedades.
        </p>
      </div>
    </div>
  </div>
</section>