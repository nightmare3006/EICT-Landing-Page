---
import SectionTitle from '../ui/SectionTitle.astro';
import Card from '../ui/Card.astro';

const contactos = [
  {
    area: 'Director General',
    icon: 'crown',
    email: 'director@eict.uho.edu.cu',
    phone: '(53) 24 483146',
    schedule: 'Lunes a Viernes, 8:00 - 17:00',
  },
  {
    area: 'Departamento Jurídico',
    icon: 'scale',
    email: 'juridica@eict.uho.edu.cu',
    phone: '(53) 24 483146',
    schedule: 'Lunes a Viernes, 8:00 - 17:00',
  },
  {
    area: 'Recursos Humanos',
    icon: 'users',
    email: 'rrhh@eict.uho.edu.cu',
    phone: '(53) 24 483146',
    schedule: '',
  },
  {
    area: 'Economía y Finanzas / Comercial',
    icon: 'trending',
    email: 'comercial.eict@uho.edu.cu',
    phone: '(53) 52117133',
    schedule: 'Lunes a Viernes, 8:00 - 17:00',
  },
];

const iconPaths: Record<string, string> = {
  crown: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />',
  scale: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />',
  users: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />',
  trending: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />',
};

const socialInfo = {
  address: 'Calle 11, No 2, entre Ave. Jorge Dimitrov y calle 10. Reparto Pedro Díaz Coello, Holguín',
  facebook: 'https://www.facebook.com/EICT-S-A-123456789',
  instagram: 'https://www.instagram.com/eict-s-a',
};
---

<section id="contacto" class="py-20 bg-gray-50 dark:bg-slate-800">
  <div class="container mx-auto px-4">
    <SectionTitle
      title="Contáctanos"
      subtitle="Comunícate directamente con el área que necesitas"
      centered
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      {contactos.map(contacto => (
        <Card>
          <div class="p-6">
            <div class="w-14 h-14 bg-eict-cyan/20 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-eict-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconPaths[contacto.icon]} />
            </div>
            <h3 class="text-lg font-bold text-eict-purple dark:text-white mb-4">{contacto.area}</h3>
            <div class="space-y-3">
              <div>
                <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Email</p>
                <a href={`mailto:${contacto.email}`} class="text-sm text-eict-cyan hover:underline block truncate">
                  {contacto.email}
                </a>
              </div>
              <div>
                <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Teléfono</p>
                <a href={`tel:${contacto.phone}`} class="text-sm text-gray-700 dark:text-gray-300 hover:text-eict-cyan transition-colors duration-200">
                  {contacto.phone}
                </a>
              </div>
              {contacto.schedule && (
                <div>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">Horario</p>
                  <p class="text-sm text-gray-600 dark:text-gray-400">{contacto.schedule}</p>
                </div>
              )}
            </div>
            <button
              class="mt-4 text-xs text-eict-cyan hover:underline copy-btn"
              data-copy={contacto.email}
              aria-label="Copiar email"
            >
              Copiar email
            </button>
          </div>
        </Card>
      ))}
    </div>

    <div class="bg-white dark:bg-slate-900 rounded-xl p-8 shadow-lg">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h4 class="text-lg font-bold text-eict-purple dark:text-white mb-4">Dirección</h4>
          <p class="text-gray-600 dark:text-gray-400 mb-6">
            <svg class="w-5 h-5 inline-block mr-2 text-eict-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {socialInfo.address}
          </p>
          <p class="text-gray-600 dark:text-gray-400">
            <svg class="w-5 h-5 inline-block mr-2 text-eict-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            eict@uho.edu.cu / comercial.eict@uho.edu.cu
          </p>
        </div>
        <div>
          <h4 class="text-lg font-bold text-eict-purple dark:text-white mb-4">Síguenos</h4>
          <div class="flex space-x-4">
            <a href={socialInfo.facebook} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-eict-cyan/20 rounded-xl flex items-center justify-center hover:bg-eict-cyan hover:text-white transition-colors duration-200 text-eict-cyan" aria-label="Facebook">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
              </svg>
            </a>
            <a href={socialInfo.instagram} target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-eict-cyan/20 rounded-xl flex items-center justify-center hover:bg-eict-cyan hover:text-white transition-colors duration-200 text-eict-cyan" aria-label="Instagram">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke-width="2" />
                <circle cx="12" cy="12" r="4" stroke-width="2" />
                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy');
      if (text) {
        await navigator.clipboard.writeText(text);
        const originalText = btn.textContent;
        btn.textContent = '¡Copiado!';
        setTimeout(() => {
          btn.textContent = originalText;
        }, 2000);
      }
    });
  });
</script>