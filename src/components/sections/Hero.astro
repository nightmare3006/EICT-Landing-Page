---
import Button from '../ui/Button.astro';
import ShareButtons from '../marketing/ShareButtons.astro';
---

<section id="inicio" class="min-h-[90vh] flex items-center justify-center relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-eict-gray-light via-white to-eict-cyan-light/30 dark:from-slate-900 dark:via-slate-800 dark:to-eict-purple/30"></div>
  
  <div class="absolute inset-0 opacity-5">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="20" cy="20" r="2" fill="currentColor" class="text-eict-purple" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="relative z-10 container mx-auto px-4 text-center">
    <div class="animate-fade-in">
      <h1 class="text-5xl md:text-7xl font-bold text-eict-purple dark:text-white mb-4">
        EICT S.A.
      </h1>
      <p class="text-2xl md:text-3xl text-eict-cyan font-semibold mb-6">
        Solucionamos con ciencia
      </p>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-10">
        Conectamos la ciencia con la empresa para transformar ideas en soluciones innovadoras.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <Button href="#servicios" variant="primary" size="lg">
          Conoce nuestros servicios
        </Button>
        <Button href="#contacto" variant="outline" size="lg">
          Contáctanos
        </Button>
      </div>

      <div class="flex justify-center">
        <ShareButtons />
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
      <a href="#nosotros" class="text-eict-purple dark:text-white hover:text-eict-cyan transition-colors duration-200" aria-label="Ir hacia abajo">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </div>
</section>