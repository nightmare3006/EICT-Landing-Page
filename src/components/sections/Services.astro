---
import { getCollection } from 'astro:content';
import SectionTitle from '../ui/SectionTitle.astro';
import Card from '../ui/Card.astro';

const servicios = (await getCollection('servicios')).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const iconMap = {
  users: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z',
  flask: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
  calendar: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  folder: 'M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z',
  globe: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<section id="servicios" class="py-24 bg-gray-50/50 dark:bg-slate-800/50">
  <div class="container mx-auto px-4">
    <SectionTitle
      title="Nuestros Servicios"
      subtitle="Soluciones científico-técnicas para impulsar tu empresa"
      centered
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:justify-items-center">
      {servicios.map((servicio) => (
        <Card class="group w-full max-w-md lg:max-w-none">
          <div class="p-8">
            <div class="w-14 h-14 bg-gradient-to-br from-eict-cyan/20 to-eict-cyan/5 rounded-2xl flex items-center justify-center mb-6 group-hover:from-eict-cyan group-hover:to-eict-cyan-dark transition-all duration-300">
              <svg class="w-7 h-7 text-eict-cyan group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconMap[servicio.data.icon ?? 'users']} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-eict-purple dark:text-white mb-3">{servicio.data.title}</h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-6">{servicio.data.description}</p>
            <a
              href="#contacto"
              class="inline-flex items-center gap-2 text-sm font-semibold text-eict-cyan hover:text-eict-cyan-dark transition-colors duration-200 group/link"
            >
              Solicitar información
              <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>