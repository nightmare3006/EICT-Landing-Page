---
import SectionTitle from '../ui/SectionTitle.astro';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';

const servicios = [
  {
    icon: 'users',
    title: 'Consultorías y asesorías',
    description: 'Diseñamos, organizamos y desarrollamos todo tipo de capacitación y superación, atendiendo a las necesidades y demandas de nuestros clientes.',
  },
  {
    icon: 'flask',
    title: 'Servicios científicos-técnicos',
    description: 'Ofrecemos soluciones a los diferentes problemas y necesidades, basadas en la innovación, la transferencia de tecnología y la aplicación de los resultados de la Ciencia y la Técnica.',
  },
  {
    icon: 'calendar',
    title: 'Organización y coordinación de eventos',
    description: 'Como organizadores profesionales de eventos académicos y científicos, colaboramos con la divulgación, organización y apoyo logístico.',
  },
  {
    icon: 'folder',
    title: 'Gestión de proyectos',
    description: 'Brindamos apoyo logístico y material para el desarrollo de las actividades de los proyectos científicos.',
  },
  {
    icon: 'globe',
    title: 'Servicios académicos internacionales',
    description: 'Gestionamos la comercialización de las ofertas académicas de las universidades asociadas, así como la exportación de servicios profesionales.',
  },
];

const iconMap: Record<string, string> = {
  users: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />',
  flask: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />',
  calendar: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />',
  folder: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />',
  globe: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
};
---

<section id="servicios" class="py-20 bg-gray-50 dark:bg-slate-800">
  <div class="container mx-auto px-4">
    <SectionTitle
      title="Nuestros Servicios"
      subtitle="Soluciones científico-técnicas para impulsar tu empresa"
      centered
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {servicios.map((servicio, index) => (
        <Card class={`${index >= 3 ? 'lg:col-start-2' : ''}`}>
          <div class="p-8">
            <div class="w-16 h-16 bg-eict-cyan/20 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-eict-cyan transition-colors duration-300">
              <svg class="w-8 h-8 text-eict-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={iconMap[servicio.icon]} />
            </div>
            <h3 class="text-xl font-bold text-eict-purple dark:text-white mb-4">{servicio.title}</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-6">{servicio.description}</p>
            <Button href="#contacto" variant="outline" size="sm">
              Más información
            </Button>
          </div>
        </Card>
      ))}
    </div>
  </div>
</section>