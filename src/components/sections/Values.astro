---
import SectionTitle from '../ui/SectionTitle.astro';

const valores = [
  { nombre: 'Solidaridad', desc: 'Apoyamos a nuestros clientes y comunidad con compromiso genuino.', num: '01', icon: 'heart' },
  { nombre: 'Laboriosidad', desc: 'Trabajamos con dedicación y esfuerzo constante por la excelencia.', num: '02', icon: 'wrench' },
  { nombre: 'Responsabilidad', desc: 'Cumplimos nuestras obligaciones con integridad y transparencia.', num: '03', icon: 'shield' },
  { nombre: 'Pasión', desc: 'Amamos lo que hacemos y lo reflejamos en cada proyecto.', num: '04', icon: 'flame' },
  { nombre: 'Compromiso', desc: 'Estamos comprometidos con la excelencia y los resultados.', num: '05', icon: 'check' },
];

const iconPaths: Record<string, string> = {
  heart: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  wrench: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  flame: 'M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z',
  check: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<section id="valores" class="py-24 bg-gradient-to-br from-eict-purple to-eict-purple-dark dark:from-slate-900 dark:to-slate-800 relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03]">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="valores-grid" width="40" height="40" patternUnits="userSpaceOnUse">
          <circle cx="20" cy="20" r="1" fill="currentColor" class="text-white" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#valores-grid)" />
    </svg>
  </div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Nuestros Valores
      </h2>
      <div class="w-20 h-1 bg-eict-cyan rounded-full mx-auto mb-6"></div>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        Los principios que guían cada decisión y cada proyecto en EICT S.A.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 md:gap-6 max-w-6xl mx-auto">
      {valores.map(valor => (
        <div class="group relative p-6 md:p-8 bg-white/[0.07] backdrop-blur-sm rounded-2xl border border-white/[0.08] hover:bg-white/[0.12] hover:border-white/20 transition-all duration-500 hover:-translate-y-1">
          <span class="absolute top-3 right-3 text-4xl font-bold text-white/[0.04] group-hover:text-white/[0.08] transition-all duration-300">{valor.num}</span>
          <div class="w-14 h-14 mx-auto mb-5 rounded-full bg-gradient-to-br from-eict-cyan to-eict-cyan-dark flex items-center justify-center shadow-lg shadow-eict-cyan/20 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[valor.icon]} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-white text-center mb-2">{valor.nombre}</h3>
          <p class="text-sm text-white/60 text-center leading-relaxed">{valor.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>